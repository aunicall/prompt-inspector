# ============================================================
# Prompt Inspector — Environment Configuration
# Copy this file to .env and fill in your values
# ============================================================

# -------------------- Database --------------------
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/prompt_inspector

# -------------------- Redis --------------------
REDIS_URL=redis://localhost:6379/0

# -------------------- Authentication --------------------
# Fixed API Key for all API requests (change this in production!)
API_KEY=change-me-in-production

# -------------------- Embedding Service --------------------
# Provider: "self_hosted" or "bailian"
EMBEDDING_PROVIDER=self_hosted

# Self-hosted embedding (TEI / OpenAI-compatible)
EMBEDDING_BASE_URL=http://127.0.0.1:8080/v1
EMBEDDING_API_KEY=not-needed
EMBEDDING_MODEL=Qwen/Qwen3-Embedding-0.6B
EMBEDDING_DIM=1024

# Bailian (DashScope) embedding
# EMBEDDING_PROVIDER=bailian
# DASHSCOPE_API_KEY=your-dashscope-api-key
# DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# DASHSCOPE_MODEL=text-embedding-v3
# DASHSCOPE_DIMENSIONS=1024

# -------------------- LLM Review --------------------
# Provider: "deepseek", "qwen", or "genai"
LLM_REVIEW_PROVIDER=genai
LLM_REVIEW_MODEL=gemini-3.1-flash-lite-preview

# LLM Augmentation (generates attack variants)
LLM_AUGMENT_PROVIDER=genai
LLM_AUGMENT_MODEL=gemini-3.1-flash-lite-preview

# Provider API Keys (set the ones you use)
# DEEPSEEK_API_KEY=your-deepseek-api-key
# DASHSCOPE_API_KEY=your-dashscope-api-key
GOOGLE_GENAI_API_KEY=your-google-genai-api-key

# -------------------- Detection Tuning --------------------
# Vector similarity thresholds (0~1)
VEC_SIM_LOW=0.60
VEC_SIM_HIGH=0.85

# Text chunking for long inputs
TEXT_CHUNK_SIZE=800
TEXT_CHUNK_OVERLAP=200

# Max input text length
MAX_TEXT_LENGTH=5000

# -------------------- CORS --------------------
# Comma-separated list of allowed origins
CORS_ORIGINS=["http://localhost:3000"]

# -------------------- Debug --------------------
DEBUG_MODE=false
